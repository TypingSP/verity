local allEvents = {}
local allFunctions = {}
local listItems = {}
local selectedObj = nil

local function PopulateList(filter)
	for _, item in ipairs(listItems) do
		item:Destroy()
	end
	listItems = {}

	local events, functions = ScanRemotes()
	allEvents = events
	allFunctions = functions

	local totalItems = 0
	local filterLower = filter and filter:lower() or ""

	local function AddItems(list, icon, color)
		for _, obj in ipairs(list) do
			local name = obj.Name
			if filterLower == "" or name:lower():find(filterLower) or obj:GetFullName():lower():find(filterLower) then
				totalItems += 1

				local item = Instance.new("TextButton")
				item.Size = UDim2.new(1, -6, 0, 26)
				item.BackgroundColor3 = Color3.fromRGB(28, 28, 38)
				item.Text = ""
				item.AutoButtonColor = false
				item.Parent = ScrollFrame

				local itemCorner = Instance.new("UICorner")
				itemCorner.CornerRadius = UDim.new(0, 4)
				itemCorner.Parent = item

				local iconLabel = Instance.new("TextLabel")
				iconLabel.Size = UDim2.new(0, 20, 1, 0)
				iconLabel.Position = UDim2.new(0, 6, 0, 0)
				iconLabel.BackgroundTransparency = 1
				iconLabel.Text = icon
				iconLabel.TextColor3 = color
				iconLabel.TextSize = 11
				iconLabel.Font = Enum.Font.GothamBold
				iconLabel.Parent = item

				local nameLabel = Instance.new("TextLabel")
				nameLabel.Size = UDim2.new(1, -30, 1, 0)
				nameLabel.Position = UDim2.new(0, 26, 0, 0)
				nameLabel.BackgroundTransparency = 1
				nameLabel.Text = name
				nameLabel.TextColor3 = Color3.fromRGB(220, 220, 240)
				nameLabel.TextSize = 11
				nameLabel.Font = Enum.Font.Gotham
				nameLabel.TextXAlignment = Enum.TextXAlignment.Left
				nameLabel.Parent = item

				item.MouseEnter:Connect(function()
					if selectedObj ~= obj then
						TweenService:Create(item, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(38, 38, 52)}):Play()
					end
				end)
				item.MouseLeave:Connect(function()
					if selectedObj ~= obj then
						TweenService:Create(item, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(28, 28, 38)}):Play()
					end
				end)

				item.MouseButton1Click:Connect(function()
					selectedObj = obj

					for _, entry in ipairs(listItems) do
						TweenService:Create(entry.button, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(28, 28, 38)}):Play()
						entry.nameLabel.TextColor3 = Color3.fromRGB(220, 220, 240)
					end

					TweenService:Create(item, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(40, 50, 90)}):Play()
					nameLabel.TextColor3 = Color3.fromRGB(120, 180, 255)

					DetailFrame.Visible = true
					DetailTitleLabel.Text = obj.Name
					PathLabel.Text = "路径：" .. obj:GetFullName()

					if obj:IsA("RemoteEvent") then
						TypeTag.Text = " RemoteEvent"
						TypeTag.TextColor3 = Color3.fromRGB(100, 200, 255)
						TypeTag.BackgroundColor3 = Color3.fromRGB(30, 50, 80)
					else
						TypeTag.Text = " RemoteFunction"
						TypeTag.TextColor3 = Color3.fromRGB(255, 200, 100)
						TypeTag.BackgroundColor3 = Color3.fromRGB(60, 45, 20)
					end

					CodeBox.Text = GenerateCode(obj)
					DetailStatus.Text = ""
				end)

				table.insert(listItems, {button = item, obj = obj, nameLabel = nameLabel})
			end
		end
	end

	AddItems(events, "⚡", Color3.fromRGB(100, 200, 255))
	AddItems(functions, "⚙", Color3.fromRGB(255, 200, 100))

	StatsLabel.Text = string.format("事件: %d | 函数: %d | 显示: %d", #events, #functions, totalItems)
	ScrollFrame.CanvasSize = UDim2.new(0, 0, 0, totalItems * 28)
end

