local function ScanRemotes()
	local events = {}
	local functions = {}
	for _, obj in ipairs(game:GetDescendants()) do
		if obj:IsA("RemoteEvent") then
			table.insert(events, obj)
		elseif obj:IsA("RemoteFunction") then
			table.insert(functions, obj)
		end
	end
	return events, functions
end

local function GenerateCode(obj)
	local name = obj.Name
	local fullName = obj:GetFullName()
	local code = ""

	if obj:IsA("RemoteEvent") then
		code = "-- 触发远程事件: " .. name .. "\n"
			.. "local ReplicatedStorage = game:GetService(\"ReplicatedStorage\")\n"
			.. "local event = " .. fullName:gsub("%.", ":WaitForChild(\"") .. "\")\n"
			.. "-- 简写路径:\n"
			.. "-- local event = ReplicatedStorage:WaitForChild(\"" .. name .. "\")\n\n"
			.. "event:FireServer()  -- 可传入参数\n"
	else
		code = "-- 调用远程函数: " .. name .. "\n"
			.. "local ReplicatedStorage = game:GetService(\"ReplicatedStorage\")\n"
			.. "local func = " .. fullName:gsub("%.", ":WaitForChild(\"") .. "\")\n"
			.. "-- 简写路径:\n"
			.. "-- local func = ReplicatedStorage:WaitForChild(\"" .. name .. "\")\n\n"
			.. "local result = func:InvokeServer()  -- 可传入参数\n"
	end

	return code
end

