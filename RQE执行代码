local dragging = false
local dragStartPos = nil
local ballStartPos = nil
local clickStartPos = nil
local dragThreshold = 8

ball.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStartPos = Vector2.new(input.Position.X, input.Position.Y)
		ballStartPos = Vector2.new(ball.AbsolutePosition.X, ball.AbsolutePosition.Y)
		clickStartPos = dragStartPos
		TweenService:Create(ball, TweenInfo.new(0.1), {Size = UDim2.new(0, 62, 0, 62)}):Play()
	end
end)

ball.InputChanged:Connect(function(input)
	if dragging then
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			local delta = Vector2.new(input.Position.X, input.Position.Y) - dragStartPos
			local screenSize = workspace.CurrentCamera.ViewportSize
			local newX = math.clamp(ballStartPos.X + delta.X, 0, screenSize.X - ball.AbsoluteSize.X)
			local newY = math.clamp(ballStartPos.Y + delta.Y, 0, screenSize.Y - ball.AbsoluteSize.Y)
			ball.Position = UDim2.new(0, newX, 0, newY)
		end
	end
end)

ball.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = false
		TweenService:Create(ball, TweenInfo.new(0.1), {Size = UDim2.new(0, 56, 0, 56)}):Play()
		if clickStartPos then
			local totalDelta = Vector2.new(input.Position.X, input.Position.Y) - clickStartPos
			if totalDelta.Magnitude < dragThreshold then
				main.Visible = true
				ball.Visible = false
			end
		end
		clickStartPos = nil
		dragStartPos = nil
		ballStartPos = nil
	end
end)

local running = false
local connection

local function stop()
	running = false
	runBtn.Text = "执 行"
	TweenService:Create(runBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(0, 170, 100)}):Play()
	if connection then connection:Disconnect() end
end

local function start()
	local freq = tonumber(freqBox.Text) or 1
	running = true
	runBtn.Text = "停 止"
	TweenService:Create(runBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(200, 60, 60)}):Play()
	connection = RunService.Heartbeat:Connect(function()
		loadstring(codeBox.Text)()
		wait(freq)
	end)
end

runBtn.MouseButton1Click:Connect(function()
	if running then stop() else start() end
end)

miniBtn.MouseButton1Click:Connect(function()
	main.Visible = false
	ball.Visible = true
end)
