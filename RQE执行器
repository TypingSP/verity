local function round(obj, radius)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius)
	c.Parent = obj
end

local function clickAnim(btn, origSize, origColor, pressColor)
	TweenService:Create(btn, TweenInfo.new(0.08), {
		Size = UDim2.new(origSize.X.Scale * 0.95, origSize.X.Offset, origSize.Y.Scale * 0.95, origSize.Y.Offset),
		BackgroundColor3 = pressColor
	}):Play()
	task.delay(0.12, function()
		TweenService:Create(btn, TweenInfo.new(0.15), {
			Size = origSize,
			BackgroundColor3 = origColor
		}):Play()
	end)
end

